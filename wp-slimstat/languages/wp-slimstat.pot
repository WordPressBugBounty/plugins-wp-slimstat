msgstr ""

#: admin/config/index.php:321
#: admin/view/wp-slimstat-db.php:68
#: src/Services/Privacy/DataExporter.php:142
msgid "City"
msgstr ""

#: admin/config/index.php:322
msgid "Choose between Country and City precision. For DB‑IP and MaxMind, City uses a larger database. For Cloudflare, city-level data requires the <strong>Add visitor location headers</strong> Managed Transform enabled in your Cloudflare dashboard (Rules &gt; Transform Rules &gt; Managed Transforms). Without it, only country is available."
msgstr ""

#: admin/config/index.php:325
